{
  "name": "s2-brand-matrix-trust-os",
  "version": "1.4.0",
  "description": "S2 商业世界树引擎。采用 HMAC-SHA256 密码学签名与宿主机环境变量进行零信任校验的本地 GEO 模拟器。",
  "main": "handler.py",
  "scripts": {
    "start": "python3 handler.py"
  },
  "author": "Space2.world",
  "license": "MIT",
  "openclaw": {
    "compat": {
      "pluginApi": "^1.0.0"
    },
    "build": {
      "openclawVersion": "^1.0.0"
    },
    "extensions": [
      "./openclaw.plugin.json"
    ],
    "configSchema": {
      "type": "object",
      "properties": {
        "S2_GEO_ADMIN_TOKEN": {
          "type": "string",
          "description": "Host-level Secret Key used for HMAC-SHA256 cryptographic signatures. Must be >= 16 chars."
        }
      },
      "required": ["S2_GEO_ADMIN_TOKEN"]
    }
  },
  "keywords": [
    "trust-engine",
    "brand-matrix",
    "zero-trust",
    "hmac-sha256",
    "openclaw-plugin"
  ],
  "dependencies": {}
}