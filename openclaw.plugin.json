{
  "id": "s2-brand-matrix-trust-os",
  "pluginId": "s2-brand-matrix-trust-os",
  "version": "1.4.0",
  "type": "native-code",
  "entry": "handler.py",
  "runtime": "python3",
  "configSchema": {
    "type": "object",
    "properties": {
      "S2_GEO_ADMIN_TOKEN": {
        "type": "string",
        "description": "Host-level Secret Key used for HMAC-SHA256 cryptographic signatures."
      }
    },
    "required": [
      "S2_GEO_ADMIN_TOKEN"
    ]
  },
  "capabilities": {
    "geo_algorithm_simulation": true,
    "hmac_sha256_cryptographic_auth": true
  },
  "permissions": {
    "tools": [
      "register_brand_root",
      "evaluate_crown_performance",
      "query_geo_ranking"
    ]
  }
}